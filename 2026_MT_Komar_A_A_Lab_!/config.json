{
  "pipeline": [
    {
      "name": "Check dotnet version",
      "command": "dotnet",
      "args": "--version",
      "stopOnFailure": true,
      "timeoutSeconds": 10
    },
    {
      "name": "Check git version",
      "command": "git",
      "args": "--version",
      "stopOnFailure": true,
      "timeoutSeconds": 10
    },
    {
      "name": "Check current directory",
      "command": "cmd",
      "args": "/c echo %CD%",
      "stopOnFailure": false,
      "timeoutSeconds": 5
    },
    {
      "name": "Create test project",
      "command": "dotnet",
      "args": "new console -n TestApp -o TestApp",
      "stopOnFailure": true,
      "timeoutSeconds": 30,
      "workingDirectory": "test_target"
    },
    {
      "name": "Restore packages",
      "command": "dotnet",
      "args": "restore",
      "stopOnFailure": true,
      "timeoutSeconds": 60,
      "workingDirectory": "test_target/TestApp"
    },
    {
      "name": "Build project",
      "command": "dotnet",
      "args": "build",
      "stopOnFailure": true,
      "timeoutSeconds": 60,
      "workingDirectory": "test_target/TestApp"
    },
    {
      "name": "Run application",
      "command": "dotnet",
      "args": "run",
      "stopOnFailure": false,
      "timeoutSeconds": 10,
      "workingDirectory": "test_target/TestApp"
    }
  ]
}